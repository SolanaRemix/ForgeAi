{
  "name": "forgeai-backend",
  "version": "1.0.0",
  "private": true,
  "description": "ForgeAI Express/WebSocket backend scaffold",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
